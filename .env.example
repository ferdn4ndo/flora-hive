# If running behind a reverse proxy, set these to the proxy's VIRTUAL_HOST and LETSENCRYPT_HOST.
VIRTUAL_HOST=
LETSENCRYPT_HOST=
LETSENCRYPT_EMAIL=

# HTTP
PORT=8080

# Optional: comma-separated browser Origins allowed for CORS (e.g. https://flora.sd40.com.br).
# Leave unset to allow any Origin (still echoes the request Origin when credentials are used).
# CORS_ALLOWED_ORIGINS=https://flora.sd40.com.br

# Production stack only (docker-compose.prod.yml). Default image is Docker Hub ferdn4ndo/flora-hive:latest.
# FLORA_HIVE_IMAGE=ferdn4ndo/flora-hive:0.2.0

# PostgreSQL — same convention as userver-filemgr (DB from userver-datamgr stack).
# Use hostname `userver-postgres` when attached to the same Docker network as userver-datamgr.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=flora_hive
POSTGRES_USER=flora_hive
# Must match the password for POSTGRES_USER on the server (SCRAM/md5). If you use the
# official Postgres image, you can set POSTGRES_PASSWORD here instead — Hive accepts either.
POSTGRES_PASS=
# POSTGRES_PASSWORD=

# Optional: superuser bootstrap (userver-filemgr setup.sh pattern). When POSTGRES_ROOT_USER
# and POSTGRES_ROOT_PASS are set, the Docker entrypoint runs scripts/docker-bootstrap-postgres.sh
# before migrate:up to create POSTGRES_DB + POSTGRES_USER with POSTGRES_PASS (or POSTGRES_PASSWORD).
# Example against userver-postgres: use the same superuser/password as the Postgres container.
# POSTGRES_ROOT_USER=postgres
# POSTGRES_ROOT_PASS=
# POSTGRES_ADMIN_DATABASE=postgres

# Optional: comma-separated keys for service-to-service access
# HIVE_API_KEYS=

# uServer-Auth
USERVER_AUTH_HOST=
USERVER_AUTH_SYSTEM_NAME=
USERVER_AUTH_SYSTEM_TOKEN=

# Bootstrap (optional; ./flora-hive bootstrap:auth, setup.sh, Docker entrypoint after migrate:up — userver-filemgr parity).
# Requires USERVER_AUTH_HOST when any bootstrap step runs (see above).
# Create-system secret for POST /auth/system (Authorization: Token …): set either USERVER_AUTH_SYSTEM_CREATION_TOKEN
# or SYSTEM_CREATION_TOKEN — same value as uServer-Auth's env SYSTEM_CREATION_TOKEN; use one name only.
# USERVER_AUTH_SYSTEM_CREATION_TOKEN=
# USERVER_AUTH_BOOTSTRAP_CUSTOM_SYSTEM_TOKEN=
# POST /auth/register: needs USERVER_AUTH_SYSTEM_NAME and USERVER_AUTH_SYSTEM_TOKEN (or token from create-system above).
# USERVER_AUTH_USER=
# USERVER_AUTH_PASSWORD=
# USERVER_AUTH_BOOTSTRAP_IS_ADMIN=   # optional: 0 or false for non-admin first user
# USERVER_AUTH_HTTP_TIMEOUT_SEC=
# ENV_FILE or HIVE_ENV_FILE — file to update with persisted tokens (default .env)
# HIVE_SKIP_PERSIST_BOOTSTRAP_ENV=1 or FILEMGR_SKIP_PERSIST_BOOTSTRAP_ENV=1 — do not write bootstrap keys to .env
# SKIP_USERVER_AUTH_SETUP=1
# SKIP_AUTH_BOOTSTRAP=1

# MQTT (URL scheme: mqtt://, mqtts://, ws://, wss://)
# userver-eventmgr: port 1883 = native MQTT only (use mqtt://…:1883). Port 9001 = WebSockets (use ws://…:9001).
# Do NOT use ws:// on 1883 — Mosquitto will drop the connection (socket hang up).
# Local broker on the host: localhost. In Docker on the same network (e.g. nginx-proxy):
# MQTT_URL=mqtt://userver-mosquitto:1883
MQTT_URL=mqtt://localhost:1883
# userver-eventmgr Mosquitto sets allow_anonymous false — set both when using that broker.
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=flora-hive

# Optional: default QoS (0|1|2) for publish endpoint when not specified
MQTT_DEFAULT_QOS=1

# Topic prefix for short names (omit or set empty to publish topics exactly as given)
FLORA_TOPIC_PREFIX=flora

# FLORA_DEVICES_SUBSCRIBE_TOPIC=flora/+/heartbeat
# FLORA_DEVICE_HEARTBEAT_TTL_SEC=180

# Docker: skip entrypoint migrations (then only `app:serve` runs)
# SKIP_CONTAINER_PREPARE=1
