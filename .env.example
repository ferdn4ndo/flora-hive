# HTTP
PORT=8080
# Comma-separated API keys (any one grants access). Generate with: openssl rand -hex 32
HIVE_API_KEYS=change-me-to-a-long-random-secret

# MQTT (URL scheme: mqtt://, mqtts://, ws://, wss://)
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=flora-hive

# Optional: default QoS (0|1|2) for publish endpoint when not specified
MQTT_DEFAULT_QOS=1

# Topic prefix for short names (omit or set empty to publish topics exactly as given)
FLORA_TOPIC_PREFIX=flora

# MQTT wildcard for device telemetry/presence (default: flora/+/+/+/heartbeat — ESP Flora firmware)
# FLORA_DEVICES_SUBSCRIBE_TOPIC=flora/+/+/+/heartbeat
# Seconds without heartbeat before device is listed as disconnected (default 180)
# FLORA_DEVICE_HEARTBEAT_TTL_SEC=180
