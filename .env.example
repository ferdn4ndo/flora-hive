# If running behind a reverse proxy, set these to the proxy's VIRTUAL_HOST and LETSENCRYPT_HOST.
VIRTUAL_HOST=
LETSENCRYPT_HOST=
LETSENCRYPT_EMAIL=

# HTTP
PORT=8080

# PostgreSQL — same convention as userver-filemgr (DB from userver-datamgr stack).
# Use hostname `userver-postgres` when attached to the same Docker network as userver-datamgr.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=flora_hive
POSTGRES_USER=flora_hive
# Must match the password for POSTGRES_USER on the server (SCRAM/md5). If you use the
# official Postgres image, you can set POSTGRES_PASSWORD here instead — Hive accepts either.
POSTGRES_PASS=
# POSTGRES_PASSWORD=

# Optional: superuser bootstrap (same pattern as userver-filemgr setup.sh). When set,
# `npm run db:prepare` (and the Docker entrypoint) creates POSTGRES_DB and POSTGRES_USER if missing.
# POSTGRES_ROOT_USER=postgres
# POSTGRES_ROOT_PASS=
# POSTGRES_ADMIN_DATABASE=postgres

# Optional: comma-separated keys for service-to-service access
# HIVE_API_KEYS=

# uServer-Auth
USERVER_AUTH_HOST=
USERVER_AUTH_SYSTEM_NAME=
USERVER_AUTH_SYSTEM_TOKEN=

# Bootstrap for `npm run db:prepare` (same pattern as userver-filemgr setup.sh):
# `USERVER_AUTH_SYSTEM_CREATION_TOKEN` — auth service env SYSTEM_CREATION_TOKEN; Authorization: Token … on POST /auth/system
# `USERVER_AUTH_USER` / `USERVER_AUTH_PASSWORD` — admin to register when login fails
# USERVER_AUTH_SYSTEM_CREATION_TOKEN=
# USERVER_AUTH_USER=
# USERVER_AUTH_PASSWORD=
# SKIP_USERVER_AUTH_SETUP=1

# MQTT (URL scheme: mqtt://, mqtts://, ws://, wss://)
# userver-eventmgr: port 1883 = native MQTT only (use mqtt://…:1883). Port 9001 = WebSockets (use ws://…:9001).
# Do NOT use ws:// on 1883 — Mosquitto will drop the connection (socket hang up).
# Local Node on the host: localhost. In Docker on the same network (e.g. nginx-proxy):
# MQTT_URL=mqtt://userver-mosquitto:1883
MQTT_URL=mqtt://localhost:1883
# userver-eventmgr Mosquitto sets allow_anonymous false — set both when using that broker.
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=flora-hive

# Optional: default QoS (0|1|2) for publish endpoint when not specified
MQTT_DEFAULT_QOS=1

# Topic prefix for short names (omit or set empty to publish topics exactly as given)
FLORA_TOPIC_PREFIX=flora

# FLORA_DEVICES_SUBSCRIBE_TOPIC=flora/environments/+/devices/+/heartbeat
# FLORA_DEVICE_HEARTBEAT_TTL_SEC=180

# Docker: skip entrypoint DB/auth bootstrap (container runs `index.js` only)
# SKIP_CONTAINER_PREPARE=1
